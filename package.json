{
  "name": "forge-mcp",
  "version": "1.0.0",
  "description": "MCP server for Salesforge products - manage contacts, sequences, domains, mailboxes and more from any MCP-compatible AI client",
  "type": "module",
  "bin": {
    "forge-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:http": "node dist/http.js",
    "dev": "tsx src/index.ts",
    "dev:http": "tsx src/http.ts"
  },
  "keywords": [
    "mcp",
    "salesforge",
    "primeforge",
    "leadsforge",
    "infraforge",
    "warmforge",
    "mcp",
    "ai",
    "sales"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "express": "^5.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
